{
  "expo": {
    "name": "BePresent",
    "slug": "bepresent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0A0A0F"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F"
      },
      "permissions": [
        "android.permission.PACKAGE_USAGE_STATS",
        "android.permission.VIBRATE"
      ]
    },
    "ios": {
      "supportsTablet": false
    },
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
